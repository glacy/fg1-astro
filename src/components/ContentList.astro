---
interface ContentListProps {
  contents: string[];
}

const { contents } = Astro.props;
---

<ul class="space-y-3">
  {contents.map((content, index) => (
    <li class="flex items-start gap-3">
      <div class="w-6 h-6 rounded-full bg-green-100 dark:bg-green-500/20 flex items-center justify-center flex-shrink-0 mt-0.5">
        <span class="text-xs font-bold text-green-600 dark:text-green-400">{index + 1}</span>
      </div>
      <p class="text-sm text-slate-700 dark:text-slate-300 leading-relaxed">{content}</p>
    </li>
  ))}
</ul>