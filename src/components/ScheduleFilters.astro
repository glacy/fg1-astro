---
import { Icon } from "astro-icon/components";

interface ScheduleFiltersProps {
  searchTerm: string;
  modalityFilter: string;
  dayFilter: string;
  instructors: string[];
  days: string[];
}

const { searchTerm, modalityFilter, dayFilter, instructors, days } =
  Astro.props;
---

<div
  class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 p-6 shadow-sm"
>
  <h2
    class="text-lg font-semibold text-slate-900 dark:text-slate-50 mb-4 flex items-center gap-2"
  >
    <Icon
      name="lucide:sliders-horizontal"
      size={20}
      class="text-blue-600 dark:text-blue-400"
      aria-hidden="true"
    />
    Filtros de búsqueda
  </h2>
  <div class="flex flex-wrap gap-4">
    <div class="flex-1 min-w-[280px]">
      <label
        for="docente-select"
        class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
      >
        Docente
      </label>
      <select
        id="docente-select"
        name="searchTerm"
        value={searchTerm}
        class="w-full px-3 py-2 bg-slate-50 dark:bg-slate-950 border border-slate-300 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-50 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
      >
        <option value="">Todos</option>
        {
          instructors.map((instructor: string) => (
            <option value={instructor}>{instructor}</option>
          ))
        }
      </select>
    </div>

    <div class="w-48">
      <label
        for="modalidad-select"
        class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
      >
        Modalidad
      </label>
      <select
        id="modalidad-select"
        name="modalityFilter"
        value={modalityFilter}
        class="w-full px-3 py-2 bg-slate-50 dark:bg-slate-950 border border-slate-300 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-50 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
      >
        <option value="">Todas</option>
        <option value="presencial">Presencial</option>
        <option value="virtual">Virtual</option>
      </select>
    </div>

    <div class="w-48">
      <label
        for="dia-select"
        class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2"
      >
        Día
      </label>
      <select
        id="dia-select"
        name="dayFilter"
        value={dayFilter}
        class="w-full px-3 py-2 bg-slate-50 dark:bg-slate-950 border border-slate-300 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-50 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
      >
        <option value="">Todos</option>
        {days.map((day: string) => <option value={day}>{day}</option>)}
      </select>
    </div>
  </div>
</div>

<script>
  function dispatchFilterChange() {
    const docente =
      (document.getElementById("docente-select") as HTMLSelectElement)?.value ??
      "";
    const modalidad =
      (document.getElementById("modalidad-select") as HTMLSelectElement)
        ?.value ?? "";
    const dia =
      (document.getElementById("dia-select") as HTMLSelectElement)?.value ?? "";
    document.dispatchEvent(
      new CustomEvent("filter-change", { detail: { docente, modalidad, dia } }),
    );
  }

  document.addEventListener("change", (e) => {
    const target = e.target as HTMLElement;
    if (target.matches("#docente-select, #modalidad-select, #dia-select")) {
      dispatchFilterChange();
    }
  });
</script>
