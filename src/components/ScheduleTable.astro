---
import { Icon } from 'astro-icon/components';
import type { Instructor } from '../lib/schedule';
import { formatLocation } from '../lib/schedule';

interface ScheduleTableProps {
  instructors: Instructor[];
}

const { instructors } = Astro.props;
---

{instructors.length === 0 ? (
  <div class="w-full min-h-96 py-20 text-center bg-white dark:bg-slate-900 rounded-2xl border border-dashed border-slate-300 dark:border-slate-700 flex flex-col items-center justify-center">
    <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-slate-50 dark:bg-slate-800 text-slate-300 dark:text-slate-600 mb-4">
      <Icon name="lucide:clock" size={32} aria-hidden="true" />
    </div>
    <h3 class="text-lg font-bold text-slate-600 dark:text-slate-400">No se encontraron horarios</h3>
    <p class="text-sm text-slate-400 dark:text-slate-500 max-w-xs mx-auto mt-2">
      Intenta con otros filtros de búsqueda.
    </p>
  </div>
) : (
  <div class="space-y-4">
    {instructors.map((instructor: Instructor) => (
      <div
        class="instructor-card bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-700 p-4 shadow-sm"
        data-instructor={instructor.docente.toLowerCase()}
      >
        <div class="mb-3 pb-3 border-b border-slate-100 dark:border-slate-800">
          <h3 class="text-base font-bold text-slate-900 dark:text-slate-50 truncate">
            {instructor.docente}
          </h3>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {instructor.atenciones.map((attention) => {
            const { text, url } = formatLocation(attention.detalle);
            return (
              <div
                class="attention-card bg-slate-50 dark:bg-slate-800 rounded-lg p-3 border border-slate-100 dark:border-slate-700 flex flex-col"
                data-modalidad={attention.modalidad}
                data-dia={attention.dia}
              >
                <div class="flex items-start justify-between gap-2 mb-2">
                  <span class="text-sm font-semibold text-slate-900 dark:text-slate-50 shrink-0">
                    {attention.dia}
                  </span>
                  <div class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-blue-50 dark:bg-blue-950/30 text-blue-600 dark:text-blue-400 flex-shrink-0">
                    {attention.modalidad === 'virtual' ? (
                      <Icon name="lucide:monitor" size={16} aria-label="Virtual" />
                    ) : (
                      <Icon name="lucide:building-2" size={16} aria-label="Presencial" />
                    )}
                  </div>
                </div>
                <div class="space-y-2 flex-1 min-w-0">
                  <div class="flex items-center gap-1.5 text-sm text-slate-600 dark:text-slate-400">
                    <Icon name="lucide:clock" size={13} aria-hidden="true" />
                    <span class="truncate" title={attention.hora}>
                      {attention.hora}
                    </span>
                  </div>
                  <div class="flex items-start gap-1 text-sm text-slate-600 dark:text-slate-400">
                    {attention.modalidad === 'virtual' ? (
                      <Icon name="lucide:video" size={13} class="mt-0.5 flex-shrink-0" aria-hidden="true" />
                    ) : (
                      <Icon name="lucide:map-pin" size={13} class="mt-0.5 flex-shrink-0" aria-hidden="true" />
                    )}
                    {url ? (
                      <a
                        href={url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-blue-600 dark:text-blue-400 hover:underline inline-flex items-center gap-1"
                      >
                        <span class="break-all text-xs" title={text}>
                          {text}
                        </span>
                      </a>
                    ) : (
                      <span class="break-all text-xs" title={text}>
                        {text}
                      </span>
                    )}
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    ))}
  </div>
)}