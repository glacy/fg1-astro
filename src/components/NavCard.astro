---
import { Icon } from "astro-icon/components";

interface Props {
  href: string;
  icon: string;
  title: string;
  description: string;
  color: "blue" | "amber" | "emerald" | "violet";
}

const { href, icon, title, description, color } = Astro.props;

const colorMap: Record<string, { border: string; bg: string; text: string; arrow: string }> = {
  blue: {
    border: "hover:border-blue-300 dark:hover:border-blue-500/30",
    bg: "bg-blue-100 dark:bg-blue-500/20",
    text: "text-blue-600 dark:text-blue-400",
    arrow: "group-hover:text-blue-500",
  },
  amber: {
    border: "hover:border-amber-300 dark:hover:border-amber-500/30",
    bg: "bg-amber-100 dark:bg-amber-500/20",
    text: "text-amber-600 dark:text-amber-400",
    arrow: "group-hover:text-amber-500",
  },
  emerald: {
    border: "hover:border-emerald-300 dark:hover:border-emerald-500/30",
    bg: "bg-emerald-100 dark:bg-emerald-500/20",
    text: "text-emerald-600 dark:text-emerald-400",
    arrow: "group-hover:text-emerald-500",
  },
  violet: {
    border: "hover:border-violet-300 dark:hover:border-violet-500/30",
    bg: "bg-violet-100 dark:bg-violet-500/20",
    text: "text-violet-600 dark:text-violet-400",
    arrow: "group-hover:text-violet-500",
  },
};

const c = colorMap[color];
---

<a
  href={href}
  class={`group relative overflow-hidden rounded-2xl border border-slate-200 dark:border-white/5 bg-white dark:bg-[#161d2a] p-6 ${c.border} hover:shadow-lg transition-all duration-200`}
>
  <div class="flex items-start justify-between mb-4">
    <div class={`w-10 h-10 rounded-xl ${c.bg} flex items-center justify-center`}>
      <Icon name={icon} size={20} class={c.text} />
    </div>
    <Icon
      name="lucide:arrow-right"
      size={16}
      class={`text-slate-300 dark:text-slate-600 ${c.arrow} group-hover:translate-x-0.5 transition-all`}
    />
  </div>
  <h2 class="text-lg font-bold text-slate-800 dark:text-white mb-1">{title}</h2>
  <p class="text-sm text-slate-500 dark:text-slate-400">{description}</p>
</a>
