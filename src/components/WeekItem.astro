---
import { Icon } from 'astro-icon/components';

interface WeekItemProps {
  week: number;
  title: string;
  isActive: boolean;
  isPast: boolean;
  isInProgress: boolean;
  isLocked: boolean;
  totalWeeks: number;
  maxCurrentWeek: number;
}

const { week, title, isActive, isPast, isInProgress, isLocked, totalWeeks, maxCurrentWeek } = Astro.props;

const showCurrentBadge = isInProgress;
const nextWeekIsLocked = week + 1 > maxCurrentWeek;
---

<a
  href={isLocked ? "#" : `/weekly/${week}`}
  data-week-item={week}
  aria-current={isInProgress ? "true" : isActive ? "page" : undefined}
  aria-disabled={isLocked}
  class={`
    w-full flex items-stretch gap-3 p-3 rounded-lg text-left transition-all duration-200 group relative hover:z-20
    ${isLocked ? 'z-0' : 'z-10'}
    ${isActive || isInProgress
      ? 'bg-blue-500/10 border border-blue-200 shadow-sm hover:bg-blue-50 dark:bg-blue-600/10 dark:border-blue-500/30 dark:hover:bg-blue-600/20'
      : isLocked
        ? 'opacity-85 pointer-events-none border border-transparent'
        : isPast
          ? 'bg-green-50/50 border border-green-200/50 hover:bg-green-50 dark:bg-green-500/5 dark:border-green-500/20 dark:hover:bg-green-500/10'
          : 'hover:bg-black/5 border border-transparent dark:hover:bg-white/5'
    }
  `}
>
  <div class="flex flex-col items-center justify-center relative flex-shrink-0" aria-hidden="true">
    {week > 1 && (
      <div class={`
        absolute -top-4 bottom-1/2 mb-2.5 left-1/2 -translate-x-1/2 w-0.5 z-10 pointer-events-none
        ${(isPast || isInProgress)
          ? 'bg-green-300 dark:bg-green-800'
          : 'bg-gray-200 dark:bg-slate-800'
        }
      `}></div>
    )}

    {week !== totalWeeks && (
      <div class={`
        absolute top-1/2 mt-2.5 -bottom-3.5 left-1/2 -translate-x-1/2 w-0.5 z-10 pointer-events-none
        ${isPast || (isInProgress && !nextWeekIsLocked)
          ? 'bg-green-300 dark:bg-green-800'
          : 'bg-gray-200 dark:bg-slate-800'
        }
      `}></div>
    )}

    <div class="relative z-20">
      <div class={`
        hidden lg:block absolute -top-8 left-1/2 -translate-x-1/2 px-2 py-1 rounded text-[10px] font-medium whitespace-nowrap opacity-0 group-hover:opacity-100 transition-all duration-200 pointer-events-none z-30 transform translate-y-1 group-hover:translate-y-0
        dark:bg-slate-700 dark:text-slate-100 bg-slate-800 text-white
      `}>
        {isPast ? 'Completada' : isInProgress ? 'En progreso' : isLocked ? 'Bloqueada' : 'Próximamente'}
        <div class={`
          absolute -bottom-1 left-1/2 -translate-x-1/2 border-x-4 border-x-transparent border-t-4
          dark:border-t-slate-700 border-t-slate-800
        `}></div>
      </div>

      {isInProgress && (
        <div
          class="absolute inset-0 rounded-full bg-blue-400/20 dark:bg-blue-500/20"
          style="animation: pulse-scale 2s ease-in-out infinite;"
        />
      )}
      <div class={`
        w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-bold border-2 relative transition-colors duration-300
        ${isActive
          ? 'bg-blue-600 border-blue-600 text-white shadow-lg shadow-blue-500/20'
          : isPast
            ? 'bg-green-500/20 border-green-500 text-green-500'
            : isLocked
              ? 'bg-gray-100 border-gray-300 text-slate-500 dark:bg-slate-800 dark:border-slate-700 dark:text-slate-400'
              : 'bg-gray-100 border-gray-200 text-slate-500 dark:bg-slate-800 dark:border-slate-700 dark:text-slate-400'
        }
      `}>
        {isPast ? (
          <Icon name="lucide:check-circle" size={12} class="w-3 h-3" aria-hidden="true" />
        ) : isLocked ? (
          <Icon name="lucide:lock" size={12} class="w-3 h-3" aria-hidden="true" />
        ) : (
          week
        )}
      </div>
    </div>
  </div>

  <div class="flex-1 overflow-hidden">
    <div class="flex items-center gap-2 mb-0.5">
      <p class={`
        text-[10px] font-bold uppercase tracking-wider
        ${isActive || isInProgress
          ? 'text-blue-500'
          : isPast
            ? 'text-green-600/80 dark:text-green-500/80'
            : isLocked
              ? 'text-slate-600 dark:text-slate-400'
              : 'text-slate-600'
        }
      `}>
        Semana {week}
      </p>
      {showCurrentBadge && (
        <div class={`
          flex items-center gap-1 px-2 py-0.5 rounded-full
          dark:bg-blue-500/15 dark:border dark:border-blue-500/30 bg-blue-100 border border-blue-200
        `} aria-label="Semana actual del curso">
          <Icon name="lucide:map-pin" size={10} class="w-2.5 h-2.5" aria-hidden="true" />
          <span class={`
            text-[9px] font-bold uppercase tracking-wider
            dark:text-blue-400 text-blue-700
          `}>
            Activa
          </span>
        </div>
      )}
    </div>
    <p class={`
      text-xs font-semibold truncate
      ${isActive || isInProgress
        ? 'text-blue-900 dark:text-white'
        : isLocked
          ? 'text-slate-600 dark:text-slate-400'
          : isPast
            ? 'text-green-700/80 group-hover:text-green-700 dark:text-green-400/80 dark:group-hover:text-green-400'
            : 'text-slate-600 group-hover:text-slate-900 dark:text-slate-300 dark:group-hover:text-white'
      }
    `}>
      {title || `Tema ${week}`}
    </p>
  </div>

  {isActive && (
    <div class="absolute right-2 top-1/2 -translate-y-1/2" aria-hidden="true">
      <div class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"></div>
    </div>
  )}
</a>

<style>
  @keyframes pulse-scale {
    0%, 100% { transform: scale(1); opacity: 0.6; }
    50% { transform: scale(1.5); opacity: 0; }
  }
</style>