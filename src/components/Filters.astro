---
interface FiltersProps {
  currentFilter: "all" | "upcoming" | "today";
}

const { currentFilter } = Astro.props;
---

<div
  class="flex flex-col sm:flex-row items-center justify-between border-b border-slate-200 dark:border-slate-800 pb-4 gap-4 sm:gap-0"
>
  <div
    class="relative bg-slate-200/50 dark:bg-slate-800 p-1 rounded-xl w-full sm:w-[320px] flex"
  >
    <!-- Animated Background Pill -->
    <div
      class="absolute top-1 bottom-1 h-[calc(100%-0.5rem)] bg-white dark:bg-slate-700 rounded-lg shadow-sm transition-all duration-300 ease-in-out filter-pill"
      style="width: auto; left: 4px;"
    >
    </div>

    <button
      data-filter="all"
      class="filter-btn relative z-10 flex-1 py-1.5 text-xs font-bold transition-colors duration-300 text-center rounded-lg focus:outline-none text-indigo-600 dark:text-indigo-400 flex items-center justify-center min-w-0"
    >
      Todos
    </button>
    <button
      data-filter="today"
      class="filter-btn relative z-10 flex-1 py-1.5 text-xs font-bold transition-colors duration-300 text-center rounded-lg focus:outline-none text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 flex items-center justify-center min-w-0"
    >
      Hoy
    </button>
    <button
      data-filter="upcoming"
      class="filter-btn relative z-10 flex-1 py-1.5 text-xs font-bold transition-colors duration-300 text-center rounded-lg focus:outline-none text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 flex items-center justify-center min-w-0"
    >
      Pendientes
    </button>
  </div>
</div>
