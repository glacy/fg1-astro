---
import { Icon } from 'astro-icon/components';
import { COURSE_CONFIG } from '../lib/shared';

interface Props {
  variant?: 'minimal' | 'full';
}

const { variant = 'full' } = Astro.props;
const { name, institution, contactEmail, githubRepository } = COURSE_CONFIG;

const copyrightText = `© 2026 Cátedra de ${name}${institution ? ` - ${institution}` : ''}`;
---

{
  variant === 'full' ? (
    <footer class="py-6 border-t border-gray-200 dark:border-white/5 text-center text-sm text-slate-400 dark:text-slate-500 transition-colors duration-300">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <p>{copyrightText}</p>
      </div>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-2">
        {githubRepository && (
          <a
            href={githubRepository}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg font-medium transition-colors text-slate-500 hover:text-slate-700 hover:bg-gray-100 dark:text-slate-400 dark:hover:text-slate-200 dark:hover:bg-white/5"
            aria-label="Ver código fuente en GitHub"
          >
            <Icon name="lucide:github" size={16} aria-hidden="true" />
            <span>Repositorio</span>
          </a>
        )}
        {contactEmail && (
          <a
            href={`mailto:${contactEmail}`}
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg font-medium transition-colors text-slate-500 hover:text-slate-700 hover:bg-gray-100 dark:text-slate-400 dark:hover:text-slate-200 dark:hover:bg-white/5"
            aria-label="Enviar correo al desarrollador"
          >
            <Icon name="lucide:mail" size={16} aria-hidden="true" />
            <span>Contacto</span>
          </a>
        )}
      </div>
    </footer>
  ) : (
    <footer class="mt-20 py-10 border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 transition-colors duration-300">
      <div class="max-w-7xl mx-auto px-6 flex flex-col items-center gap-2 mt-2">
        <p class="text-sm text-slate-400 dark:text-slate-500 font-medium">
          {copyrightText}
        </p>
        <div class="flex items-center gap-2">
          {githubRepository && (
            <a
              href={githubRepository}
              target="_blank"
              rel="noopener noreferrer"
              class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors p-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800"
              aria-label="Ver repositorio en GitHub"
            >
              <Icon name="lucide:github" size={20} />
            </a>
          )}
          {contactEmail && (
            <a
              href={`mailto:${contactEmail}`}
              class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors p-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800"
              aria-label="Enviar correo al desarrollador"
            >
              <Icon name="lucide:mail" size={20} />
            </a>
          )}
        </div>
      </div>
    </footer>
  )
}