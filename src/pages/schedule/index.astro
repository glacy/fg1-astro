---
import ShellLayout from '../../layouts/ShellLayout.astro';
import Sidebar from '../../components/Sidebar.astro';

import { Icon } from 'astro-icon/components';
import ScheduleFilters from '../../components/ScheduleFilters.astro';
import ScheduleTable from '../../components/ScheduleTable.astro';
import { filterInstructors, getInstructorsList, days } from '../../lib/schedule';

// Obtener todos los instructores para mostrar inicialmente
const allInstructors = filterInstructors('', '', '');
const instructorsList = getInstructorsList();
---

<ShellLayout title="Horarios" activeTab="schedule">
  <slot name="sidebar" slot="sidebar">
    <Sidebar activeTab="schedule" />
  </slot>
  <div id="schedule-root" class="w-full h-full bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-50 transition-colors duration-300 flex flex-col">
    <main class="w-full px-4 sm:px-6 lg:px-8 pt-4 pb-4 flex-1 overflow-auto min-w-0">
      <div class="space-y-8 max-w-7xl mx-auto">
        <div class="text-center sm:text-left">
          <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-slate-50 mb-2">
            Horarios de Atención Estudiantil
          </h1>
          <p class="text-sm text-slate-600 dark:text-slate-400">I Semestre 2026</p>
        </div>

        <div class="flex flex-wrap gap-4 text-sm text-slate-600 dark:text-slate-400">
          <div class="flex items-center gap-2 bg-white dark:bg-slate-900 px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-800">
            <div class="w-8 h-8 rounded-full bg-blue-50 dark:bg-blue-950/30 text-blue-600 dark:text-blue-400 flex items-center justify-center">
              <Icon name="lucide:building-2" size={16} aria-hidden="true" />
            </div>
            <span>Presencial</span>
          </div>
          <div class="flex items-center gap-2 bg-white dark:bg-slate-900 px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-800">
            <div class="w-8 h-8 rounded-full bg-blue-50 dark:bg-blue-950/30 text-blue-600 dark:text-blue-400 flex items-center justify-center">
              <Icon name="lucide:monitor" size={16} aria-hidden="true" />
            </div>
            <span>Virtual</span>
          </div>
        </div>

        <ScheduleFilters
          searchTerm=""
          modalityFilter=""
          dayFilter=""
          instructors={instructorsList}
          days={days}
        />

        <ScheduleTable instructors={allInstructors} />

        <div id="no-results" class="hidden w-full min-h-96 py-20 text-center bg-white dark:bg-slate-900 rounded-2xl border border-dashed border-slate-300 dark:border-slate-700 flex flex-col items-center justify-center">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-slate-50 dark:bg-slate-800 text-slate-300 dark:text-slate-600 mb-4">
            <Icon name="lucide:clock" size={32} aria-hidden="true" />
          </div>
          <h3 class="text-lg font-bold text-slate-600 dark:text-slate-400">No se encontraron horarios</h3>
          <p class="text-sm text-slate-400 dark:text-slate-500 max-w-xs mx-auto mt-2">
            Intenta con otros filtros de búsqueda.
          </p>
        </div>
      </div>
    </main>
  </div>
</ShellLayout>

<script client:load>
  function setupFilters() {
    const instructorSelect = document.getElementById('docente-select');
    const modalitySelect = document.getElementById('modalidad-select');
    const daySelect = document.getElementById('dia-select');
    const instructorCards = document.querySelectorAll('.instructor-card');
    const noResults = document.getElementById('no-results');

    if (!instructorSelect || !modalitySelect || !daySelect || !instructorCards.length) return;

    function filterSchedule() {
      const instructorValue = instructorSelect.value.toLowerCase();
      const modalityValue = modalitySelect.value;
      const dayValue = daySelect.value;
      
      let visibleCount = 0;

      instructorCards.forEach(card => {
        const instructorName = card.dataset.instructor || '';
        const attentionCards = card.querySelectorAll('.attention-card');
        
        let hasVisibleAttention = false;

        const instructorMatch = !instructorValue || instructorName.includes(instructorValue);
        
        if (!instructorMatch) {
          card.style.display = 'none';
          return;
        }

        attentionCards.forEach(attention => {
          const modality = attention.dataset.modalidad || '';
          const dia = attention.dataset.dia || '';
          
          const modalityMatch = !modalityValue || modality === modalityValue;
          const dayMatch = !dayValue || dia === dayValue;
          
          if (modalityMatch && dayMatch) {
            attention.style.display = 'flex';
            hasVisibleAttention = true;
          } else {
            attention.style.display = 'none';
          }
        });

        if (hasVisibleAttention) {
          card.style.display = 'block';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      if (noResults) {
        noResults.classList.toggle('hidden', visibleCount > 0);
      }
    }

    instructorSelect.addEventListener('change', filterSchedule);
    modalitySelect.addEventListener('change', filterSchedule);
    daySelect.addEventListener('change', filterSchedule);
  }

  setupFilters();
  document.addEventListener('astro:after-swap', setupFilters);
</script>
