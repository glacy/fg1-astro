---
import { Image } from "astro:assets";
import ShellLayout from "../../layouts/ShellLayout.astro";
import Sidebar from "../../components/Sidebar.astro";
import WeekTimeline from "../../components/WeekTimeline.astro";
import Section from "../../components/Section.astro";
import ObjectivesList from "../../components/ObjectivesList.astro";
import ContentList from "../../components/ContentList.astro";
import LinkCard from "../../components/LinkCard.astro";
import WeekNavigation from "../../components/WeekNavigation.astro";
import { loadWeeksData, COURSE_CONFIG } from "../../lib/weekly/weeks";

export const prerender = true;

export function getStaticPaths() {
  const paths = [];
  for (let i = 1; i <= COURSE_CONFIG.maxCurrentWeek; i++) {
    paths.push({ params: { semana: i.toString() } });
  }
  return paths;
}

const { semana } = Astro.params;
const currentWeek = parseInt(semana);
const maxCurrentWeek = COURSE_CONFIG.maxCurrentWeek;
const totalWeeks = COURSE_CONFIG.totalWeeks;

if (currentWeek > maxCurrentWeek) {
  return Astro.redirect("/weekly/1");
}

// Validación para asegurar que currentWeek sea válido
const validWeek = Math.max(1, Math.min(currentWeek, totalWeeks));
const weeksData = await loadWeeksData();
const weekData = weeksData[validWeek];
const isOpen = false;
const isDesktop = false;
---

<ShellLayout title="Plan Semanal" activeTab="weekly">
  <slot name="sidebar" slot="sidebar">
    <Sidebar activeTab="weekly" />
  </slot>
  <div
    class="w-full h-full bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-50 transition-colors duration-300 flex flex-col"
    data-max-week={maxCurrentWeek}
  >
    <main
      class="w-full px-4 sm:px-6 lg:px-8 pt-4 pb-4 flex-1 overflow-auto min-w-0"
    >
      <div class="space-y-8 max-w-7xl mx-auto">
        <div class="flex flex-col lg:flex-row gap-4 lg:gap-8">
          <aside
            class="w-auto lg:w-72 lg:flex-shrink-0 lg:sticky lg:top-4 lg:self-start z-40 relative min-w-0"
          >
            <WeekTimeline
              currentWeek={currentWeek}
              totalWeeks={totalWeeks}
              maxCurrentWeek={maxCurrentWeek}
              isOpen={isOpen}
              isDesktop={isDesktop}
            />
          </aside>

          <div class="flex-1 p-6">
            <div class="flex-1 w-auto mx-auto pb-20" role="main">
              <div
                class="bg-white dark:bg-[#161d2a] rounded-2xl border border-gray-200 dark:border-white/5 shadow-sm overflow-hidden mb-8"
              >
                <div class="relative h-48 md:h-64 overflow-hidden">
                  <Image
                    src={weekData.image}
                    alt={weekData.title}
                    class="w-full h-full object-cover"
                    width={1000}
                    height={667}
                    loading="lazy"
                  />
                  <div
                    class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"
                  >
                  </div>
                  <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8">
                    <div class="flex items-center gap-2 mb-3">
                      <div
                        class="px-3 py-1 rounded-full bg-blue-500/20 border border-blue-500/30"
                      >
                        <span
                          class="text-xs font-bold text-blue-400 uppercase tracking-wider"
                          >Semana {currentWeek}</span
                        >
                      </div>
                    </div>
                    <h1 class="text-2xl md:text-3xl font-bold text-white mb-2">
                      {weekData.title}
                    </h1>
                  </div>
                </div>
              </div>

              <Section title="Objetivos de aprendizaje">
                <ObjectivesList objectives={weekData.objetivos} />
              </Section>

              <Section title="Contenidos">
                <ContentList contents={weekData.contenidos} />
              </Section>

              <!-- <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-6"> -->
              <Section title="Materiales">
                <div class="grid gap-3">
                  {
                    weekData.consignas.length > 0 ? (
                      weekData.consignas.map((item, i) => (
                        <LinkCard
                          key={i}
                          text={item.text}
                          url={item.url}
                          icon={item.icon}
                        />
                      ))
                    ) : (
                      <p class="text-slate-600 dark:text-slate-400 italic text-sm text-center py-4">
                        Sin materiales asignados
                      </p>
                    )
                  }
                </div>
              </Section>

              <Section title="Actividades">
                <div class="grid gap-3">
                  {
                    weekData.evaluaciones.length > 0 ? (
                      weekData.evaluaciones.map((item, i) => (
                        <LinkCard
                          key={i}
                          text={item.text}
                          url={item.url}
                          icon={item.icon}
                          variant="evaluation"
                        />
                      ))
                    ) : (
                      <p class="text-slate-600 dark:text-slate-400 italic text-sm text-center py-4">
                        Sin evaluaciones pendientes
                      </p>
                    )
                  }
                </div>
              </Section>
              <!-- </div> -->

              {
                weekData.recursos && weekData.recursos.length > 0 && (
                  <Section title="Recursos complementarios">
                    {/* <div class="grid gap-3 sm:grid-cols-2"> */}
                    {weekData.recursos.map((item, i) => (
                      <LinkCard
                        key={i}
                        text={item.text}
                        url={item.url}
                        icon={item.icon}
                      />
                    ))}
                    {/* </div> */}
                  </Section>
                )
              }

              <WeekNavigation
                currentWeek={currentWeek}
                totalWeeks={totalWeeks}
                maxCurrentWeek={maxCurrentWeek}
              />
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</ShellLayout>

<script>
  function setupWeeklyPlan() {
    const weekItems = document.querySelectorAll("[data-week-item]");
    const timelineToggle = document.querySelector("[data-timeline-toggle]");
    const timelineContainer = document.querySelector(
      "[data-timeline-container]",
    );
    const prevButton = document.querySelector('[data-nav="previous"]');
    const nextButton = document.querySelector('[data-nav="next"]');

    const currentWeek = parseInt(
      window.location.pathname.match(/\/weekly\/(\d+)/)?.[1] || "1",
    );
    let isOpen = false;
    let isDesktop = window.innerWidth >= 1024;
    const maxCurrentWeek = parseInt(
      document.querySelector("[data-max-week]")?.getAttribute("data-max-week") || "1",
    );

    function checkIsDesktop() {
      isDesktop = window.innerWidth >= 1024;
      if (isDesktop && !isOpen) {
        isOpen = true;
        updateTimelineVisibility();
      }
    }

    function updateTimelineVisibility() {
      if (timelineContainer) {
        if (isOpen || isDesktop) {
          timelineContainer.classList.remove("h-0", "opacity-0");
          timelineContainer.classList.add("h-auto", "opacity-100");
        } else {
          timelineContainer.classList.add("h-0", "opacity-0");
          timelineContainer.classList.remove("h-auto", "opacity-100");
        }
      }
    }

    function navigateToWeek(week) {
      window.location.href = `/weekly/${week}`;
    }

    function updateNavigation() {
      if (prevButton) {
        prevButton.disabled = currentWeek <= 1;
      }
      if (nextButton) {
        nextButton.disabled = currentWeek >= maxCurrentWeek;
      }
    }

    function setupTimeline() {
      if (timelineToggle) {
        timelineToggle.addEventListener("click", () => {
          isOpen = !isOpen;
          updateTimelineVisibility();
        });
      }

      weekItems.forEach((button) => {
        button.addEventListener("click", () => {
          const week = parseInt(button.getAttribute("data-week-item"));
          if (week && week <= maxCurrentWeek) {
            navigateToWeek(week);
            isOpen = false;
            updateTimelineVisibility();
          }
        });
      });
    }

    function setupNavigation() {
      if (prevButton) {
        prevButton.addEventListener("click", () => {
          navigateToWeek(currentWeek - 1);
        });
      }

      if (nextButton) {
        nextButton.addEventListener("click", () => {
          navigateToWeek(currentWeek + 1);
        });
      }
    }

    window.addEventListener("resize", checkIsDesktop);

    checkIsDesktop();
    updateNavigation();
    setupTimeline();
    setupNavigation();
  }

  setupWeeklyPlan();
</script>
